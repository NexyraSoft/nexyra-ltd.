# Backend Configuration (for Render)
PORT=5000
NODE_ENV=production

# Database
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/nexyrasoft"

# Security
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars-recommended"

# Frontend URL (CORS) - Update based on deployment
# Development
# CLIENT_URL="http://localhost:3000"
# Production (Vercel)
CLIENT_URL="https://nexyra-ltd-frontend.vercel.app"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
# Use false for port 587 (STARTTLS). Use true for port 465 (SMTPS).
SMTP_SECURE=false
SMTP_USER="nexyrasoft@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM_NAME="NexyraSoft"
COMPANY_NOTIFICATION_EMAIL="nexyrasoft@gmail.com"

# Frontend Configuration (for Vercel)
# API Endpoint - Update based on backend deployment
VITE_API_URL="https://nexyrasoft-backend.onrender.com/api"
