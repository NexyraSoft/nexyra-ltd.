# Vercel Deployment - Files to Ignore

# Source files (already compiled)
**/*.ts
**/*.tsx
**/*.jsx
tsconfig.json
vite.config.js

# Development
.env.development
.env.local
.env.*.local

# Build tools
node_modules/
.git
.gitignore
.prettierignore
.eslintignore

# Documentation
*.md
!DEPLOYMENT.md
docs/

# IDE & OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~
.env.example

# Backend (not needed for frontend)
backend/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache
.cache/
.next/
.nuxt/

# Testing
test/
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/

# Miscellaneous
.planning/
*.pem
.env.*.local
